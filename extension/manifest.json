{
  "manifest_version": 3,
  "name": "Summit — Job Tracker",
  "version": "2.0.0",
  "description": "Add any job posting to Summit in one click. Works on LinkedIn, Indeed, Greenhouse, Workday, and more.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://jobsummit.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
