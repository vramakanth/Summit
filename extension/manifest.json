{
  "manifest_version": 3,
  "name": "Applied — Job Tracker",
  "version": "1.0.0",
  "description": "Add job postings to your Applied tracker in one click from any page.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}